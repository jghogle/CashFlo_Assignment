[{"rule_id":"AP-VAL-001","source_clause":"Section 1.1","description":"Invoice must contain all mandatory fields: Invoice Number, Invoice Date, Vendor GSTIN, PO Number, and Grand Total Amount. Missing any field routes to AP Clerk.","category":"BASIC_VALIDATION","priority":10,"scope":"INVOICE","condition":{"operator":"OR","operands":[{"field":"invoice_number","op":"is_null"},{"field":"invoice_date","op":"is_null"},{"field":"vendor_gstin","op":"is_null"},{"field":"po_number","op":"is_null"},{"field":"grand_total","op":"is_null"}]},"action":"FLAG_INCOMPLETE","action_details":{"status":"FLAGGED","flag":"Incomplete Invoice","route_to":"AP_CLERK","reason":"One or more mandatory fields are missing"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["mandatory_fields","basic_validation","routing"]},{"rule_id":"AP-VAL-002","source_clause":"Section 1.2","description":"Invoice date cannot be in the future (later than the current processing date). Future-dated invoices must be rejected.","category":"BASIC_VALIDATION","priority":15,"scope":"INVOICE","condition":{"field":"invoice_date","op":"gt","value_field":"processing_date"},"action":"REJECT","action_details":{"status":"REJECTED","reason":"Future-Dated Invoice Not Permitted","route_to":null},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["date_validation","rejection"]},{"rule_id":"AP-VAL-003","source_clause":"Section 1.3","description":"Handwritten invoices above INR 50,000 require additional approval from the AP Manager before booking.","category":"BASIC_VALIDATION","priority":20,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"is_handwritten","op":"eq","value":true},{"field":"invoice_total","op":"gt","value":50000}]},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"AP_MANAGER","reason":"Handwritten invoice above INR 50,000 requires AP Manager approval"},"requires_justification":false,"notification":null,"confidence":0.97,"tags":["handwritten","approval","amount_threshold"]},{"rule_id":"AP-VAL-004","source_clause":"Section 1.4","description":"Duplicate invoice detection: if an invoice with the same Invoice Number and Vendor GSTIN already exists in the system, flag as Potential Duplicate and hold for review.","category":"BASIC_VALIDATION","priority":12,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_number","op":"eq","value_field":"existing_invoice_number"},{"field":"vendor_gstin","op":"eq","value_field":"existing_invoice_vendor_gstin"}]},"action":"FLAG_DUPLICATE","action_details":{"status":"HELD","flag":"Potential Duplicate","route_to":"AP_CLERK","reason":"Invoice with same Invoice Number and Vendor GSTIN already exists in system"},"requires_justification":false,"notification":null,"confidence":0.98,"tags":["duplicate_detection","hold"]},{"rule_id":"AP-PO-001","source_clause":"Section 2.1","description":"Every invoice must reference a valid, active PO. If PO Number does not match any active PO in the system, reject the invoice.","category":"PO_MATCHING","priority":25,"scope":"INVOICE","condition":{"operator":"OR","operands":[{"field":"po_exists","op":"eq","value":false},{"field":"po_number","op":"is_null"}]},"action":"REJECT","action_details":{"status":"REJECTED","reason":"Invalid PO Reference","route_to":null},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["po_validation","rejection"]},{"rule_id":"AP-PO-002","source_clause":"Section 2.2(a)","description":"If Invoice Total Amount is within +/- 1% of the PO Amount, the invoice is auto-approved for booking.","category":"PO_MATCHING","priority":30,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"gte","expr":"po_amount * 0.99"},{"field":"invoice_total","op":"lte","expr":"po_amount * 1.01"}]},"action":"AUTO_APPROVE","action_details":{"status":"AUTO_APPROVED","reason":"Invoice amount within +/- 1% tolerance of PO amount","route_to":null},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["amount_matching","auto_approve","tolerance"]},{"rule_id":"AP-PO-003","source_clause":"Section 2.2(b)","description":"If Invoice Total Amount exceeds PO Amount by more than 1% but less than 10%, route to Department Head for approval.","category":"PO_MATCHING","priority":35,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"gt","expr":"po_amount * 1.01"},{"field":"invoice_total","op":"lt","expr":"po_amount * 1.10"}]},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"DEPARTMENT_HEAD","reason":"Invoice amount exceeds PO by 1%–10%"},"requires_justification":false,"notification":{"type":"email","to":["department_head"],"trigger":"ON_ROUTE","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.98,"tags":["amount_matching","routing","department_head"]},{"rule_id":"AP-PO-004","source_clause":"Section 2.2(c)","description":"If Invoice Total Amount exceeds PO Amount by 10% or more, escalate to Finance Controller with mandatory justification note.","category":"PO_MATCHING","priority":40,"scope":"INVOICE","condition":{"field":"invoice_total","op":"gte","expr":"po_amount * 1.10"},"action":"ESCALATE","action_details":{"status":"ESCALATED","route_to":"FINANCE_CONTROLLER","reason":"Invoice amount exceeds PO by 10% or more — mandatory justification required"},"requires_justification":true,"notification":{"type":"email","to":["finance_controller","internal_audit"],"trigger":"ON_ESCALATE","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.99,"tags":["amount_matching","escalation","finance_controller","critical_deviation"]},{"rule_id":"AP-PO-005","source_clause":"Section 2.2(d)","description":"If Invoice Total Amount is less than PO Amount by more than 5%, raise flag 'Under-Invoiced — Verify Partial Delivery'.","category":"PO_MATCHING","priority":32,"scope":"INVOICE","condition":{"field":"invoice_total","op":"lt","expr":"po_amount * 0.95"},"action":"FLAG_WARNING","action_details":{"status":"FLAGGED","flag":"Under-Invoiced — Verify Partial Delivery","route_to":"AP_CLERK","reason":"Invoice total is more than 5% below PO amount"},"requires_justification":false,"notification":null,"confidence":0.97,"tags":["amount_matching","under_invoicing","warning"]},{"rule_id":"AP-PO-006","source_clause":"Section 2.3(b)","description":"If Invoice Quantity exceeds PO Quantity for any line item, hold the invoice with flag 'Quantity Exceeds PO'.","category":"PO_MATCHING","priority":45,"scope":"LINE_ITEM","condition":{"field":"invoice_qty","op":"gt","value_field":"po_qty"},"action":"HOLD","action_details":{"status":"HELD","flag":"Quantity Exceeds PO","route_to":"PROCUREMENT","reason":"Invoice quantity exceeds PO quantity for one or more line items"},"requires_justification":false,"notification":{"type":"email","to":["department_head"],"trigger":"ON_HOLD","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.99,"tags":["quantity_matching","hold","line_item"]},{"rule_id":"AP-PO-007","source_clause":"Section 2.3(c)","description":"If Invoice Unit Rate differs from PO Unit Rate by more than 2% for any line item, flag as 'Rate Mismatch' and route to Procurement for verification.","category":"PO_MATCHING","priority":46,"scope":"LINE_ITEM","condition":{"field":"abs_rate_deviation_pct","op":"gt","value":2},"action":"FLAG_AND_ROUTE","action_details":{"status":"FLAGGED","flag":"Rate Mismatch","route_to":"PROCUREMENT","reason":"Invoice unit rate differs from PO unit rate by more than 2%"},"requires_justification":false,"notification":{"type":"email","to":["procurement"],"trigger":"ON_FLAG","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.98,"tags":["rate_matching","routing","procurement","line_item"]},{"rule_id":"AP-GRN-001","source_clause":"Section 3.1","description":"For goods-based POs, a valid GRN must exist before the invoice can be booked. If no GRN is found, hold with status 'Awaiting GRN'.","category":"GRN_MATCHING","priority":50,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"is_goods_based","op":"eq","value":true},{"operator":"OR","operands":[{"field":"grn_exists","op":"eq","value":false},{"field":"grn_number","op":"is_null"}]}]},"action":"HOLD","action_details":{"status":"HELD","flag":"Awaiting GRN","route_to":"AP_CLERK","reason":"No valid GRN found for this goods-based PO"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["grn_matching","hold","goods_based"]},{"rule_id":"AP-GRN-002","source_clause":"Section 3.2(b)","description":"If Invoice Quantity exceeds GRN Quantity for any line item, reject the invoice with reason 'Invoice Qty Exceeds Received Qty'. Refer Section 2.3(b) for PO-level escalation.","category":"GRN_MATCHING","priority":55,"scope":"LINE_ITEM","condition":{"field":"invoice_qty","op":"gt","value_field":"grn_qty"},"action":"REJECT","action_details":{"status":"REJECTED","reason":"Invoice Qty Exceeds Received Qty","cross_reference":"Section 2.3(b)","route_to":null},"requires_justification":false,"notification":{"type":"email","to":["department_head"],"trigger":"ON_REJECT","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.99,"tags":["grn_matching","quantity_matching","rejection","line_item"]},{"rule_id":"AP-GRN-003","source_clause":"Section 3.3","description":"GRN Date must be on or before Invoice Date. If GRN Date is after Invoice Date, flag with 'GRN Post-Dated — Verify Receipt Timeline'.","category":"GRN_MATCHING","priority":52,"scope":"INVOICE","condition":{"field":"grn_date","op":"gt","value_field":"invoice_date"},"action":"FLAG_WARNING","action_details":{"status":"FLAGGED","flag":"GRN Post-Dated — Verify Receipt Timeline","route_to":"AP_CLERK","reason":"GRN date is after invoice date"},"requires_justification":false,"notification":null,"confidence":0.97,"tags":["grn_matching","date_validation","warning"]},{"rule_id":"AP-TAX-001","source_clause":"Section 4.1","description":"Vendor GSTIN on the invoice must match GSTIN registered in the vendor master. Mismatch results in rejection.","category":"TAX_COMPLIANCE","priority":60,"scope":"INVOICE","condition":{"field":"vendor_gstin","op":"neq","value_field":"vendor_gstin_in_master"},"action":"REJECT","action_details":{"status":"REJECTED","reason":"GSTIN Mismatch — Update Vendor Master or Verify Invoice","route_to":null},"requires_justification":false,"notification":{"type":"email","to":["finance_controller","internal_audit"],"trigger":"ON_REJECT","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.99,"tags":["gstin_validation","compliance","rejection","critical_deviation"]},{"rule_id":"AP-TAX-002","source_clause":"Section 4.2","description":"PAN embedded in vendor's GSTIN (characters 3–12) must match the PAN on file. Mismatch triggers a compliance hold.","category":"TAX_COMPLIANCE","priority":62,"scope":"INVOICE","condition":{"field":"gstin_embedded_pan","op":"neq","value_field":"vendor_pan_on_file"},"action":"COMPLIANCE_HOLD","action_details":{"status":"HELD","flag":"PAN-GSTIN Mismatch","route_to":"COMPLIANCE_TEAM","reason":"PAN embedded in GSTIN does not match PAN on file"},"requires_justification":false,"notification":{"type":"email","to":["finance_controller","internal_audit"],"trigger":"ON_HOLD","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.96,"tags":["pan_validation","gstin_validation","compliance","hold","critical_deviation"]},{"rule_id":"AP-TAX-003","source_clause":"Section 4.3(a)","description":"Total Taxable Amount + Total Tax Amount must equal the Grand Total (within INR 1 tolerance for rounding). Failure flags Tax Calculation Error.","category":"TAX_COMPLIANCE","priority":65,"scope":"INVOICE","condition":{"field":"abs_tax_calculation_error","op":"gt","value":1},"action":"FLAG_ERROR","action_details":{"status":"FLAGGED","flag":"Tax Calculation Error","route_to":"AP_CLERK","reason":"Taxable Amount + Tax Amount does not equal Grand Total (variance > INR 1)"},"requires_justification":false,"notification":null,"confidence":0.98,"tags":["tax_calculation","compliance","error"]},{"rule_id":"AP-TAX-004","source_clause":"Section 4.3(b)","description":"For intra-state supply: CGST and SGST must each be present and equal; IGST must be zero.","category":"TAX_COMPLIANCE","priority":66,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"supply_type","op":"eq","value":"intra_state"},{"operator":"OR","operands":[{"field":"cgst","op":"is_null"},{"field":"sgst","op":"is_null"},{"field":"cgst","op":"neq","value_field":"sgst"},{"field":"igst","op":"gt","value":0}]}]},"action":"FLAG_ERROR","action_details":{"status":"FLAGGED","flag":"Tax Calculation Error","route_to":"AP_CLERK","reason":"Intra-state supply must have CGST = SGST with no IGST"},"requires_justification":false,"notification":null,"confidence":0.97,"tags":["tax_validation","intra_state","cgst","sgst","compliance"]},{"rule_id":"AP-TAX-005","source_clause":"Section 4.3(c)","description":"For inter-state supply: IGST must be present; CGST and SGST must be zero.","category":"TAX_COMPLIANCE","priority":67,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"supply_type","op":"eq","value":"inter_state"},{"operator":"OR","operands":[{"field":"igst","op":"is_null"},{"field":"igst","op":"lte","value":0},{"field":"cgst","op":"gt","value":0},{"field":"sgst","op":"gt","value":0}]}]},"action":"FLAG_ERROR","action_details":{"status":"FLAGGED","flag":"Tax Calculation Error","route_to":"AP_CLERK","reason":"Inter-state supply must have IGST only; CGST and SGST must be zero"},"requires_justification":false,"notification":null,"confidence":0.97,"tags":["tax_validation","inter_state","igst","compliance"]},{"rule_id":"AP-TAX-006","source_clause":"Section 4.4","description":"Place of Supply must match the state code in the buyer's GSTIN. Mismatch results in a flag.","category":"TAX_COMPLIANCE","priority":68,"scope":"INVOICE","condition":{"field":"place_of_supply_state_code","op":"neq","value_field":"buyer_gstin_state_code"},"action":"FLAG_WARNING","action_details":{"status":"FLAGGED","flag":"Place of Supply Mismatch","route_to":"AP_CLERK","reason":"Place of Supply state code does not match buyer's GSTIN state code"},"requires_justification":false,"notification":null,"confidence":0.96,"tags":["place_of_supply","gstin_validation","compliance","warning"]},{"rule_id":"AP-APR-001","source_clause":"Section 5.1","description":"Invoices up to INR 1,00,000 are auto-approved if all validations in Sections 1–4 pass.","category":"APPROVAL_MATRIX","priority":80,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"lte","value":100000},{"field":"all_validations_passed","op":"eq","value":true},{"field":"vendor_on_watchlist","op":"eq","value":false}]},"action":"AUTO_APPROVE","action_details":{"status":"AUTO_APPROVED","reason":"Invoice amount within auto-approval threshold and all validations passed","route_to":null},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["approval_matrix","auto_approve","amount_threshold"]},{"rule_id":"AP-APR-002","source_clause":"Section 5.2","description":"Invoices between INR 1,00,001 and INR 10,00,000 require approval from the Department Head.","category":"APPROVAL_MATRIX","priority":82,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"gt","value":100000},{"field":"invoice_total","op":"lte","value":1000000}]},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"DEPARTMENT_HEAD","reason":"Invoice amount between INR 1L and INR 10L requires Department Head approval"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["approval_matrix","department_head","amount_threshold"]},{"rule_id":"AP-APR-003","source_clause":"Section 5.3","description":"Invoices between INR 10,00,001 and INR 50,00,000 require approval from the Finance Controller.","category":"APPROVAL_MATRIX","priority":84,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"gt","value":1000000},{"field":"invoice_total","op":"lte","value":5000000}]},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"FINANCE_CONTROLLER","reason":"Invoice amount between INR 10L and INR 50L requires Finance Controller approval"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["approval_matrix","finance_controller","amount_threshold"]},{"rule_id":"AP-APR-004","source_clause":"Section 5.4","description":"Invoices above INR 50,00,000 require approval from the CFO. Subject to additional audit trail documentation per Section 6.","category":"APPROVAL_MATRIX","priority":86,"scope":"INVOICE","condition":{"field":"invoice_total","op":"gt","value":5000000},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"CFO","reason":"Invoice amount above INR 50L requires CFO approval","cross_reference":"Section 6 — additional audit trail documentation required"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["approval_matrix","cfo","amount_threshold","audit_trail"]},{"rule_id":"AP-APR-005","source_clause":"Section 5.5","description":"Exception to Section 5.1: If the vendor is on the Watch List (compliance or payment history issues), all invoices regardless of amount require Department Head approval.","category":"APPROVAL_MATRIX","priority":78,"scope":"INVOICE","condition":{"field":"vendor_on_watchlist","op":"eq","value":true},"action":"ROUTE_FOR_APPROVAL","action_details":{"status":"PENDING_APPROVAL","route_to":"DEPARTMENT_HEAD","reason":"Vendor is on Watch List — Department Head approval required regardless of invoice amount"},"requires_justification":false,"notification":null,"confidence":0.98,"tags":["approval_matrix","watchlist_vendor","exception","department_head"]},{"rule_id":"AP-NOT-001","source_clause":"Section 6.1","description":"Any deviation detected during three-way match (Sections 2–3) must trigger an email notification to the relevant stakeholder within 15 minutes of detection.","category":"DEVIATION_NOTIFICATIONS","priority":90,"scope":"INVOICE","condition":{"field":"has_three_way_match_deviation","op":"eq","value":true},"action":"SEND_NOTIFICATION","action_details":{"notification_type":"email","route_to":"RELEVANT_STAKEHOLDER","within_minutes":15},"requires_justification":false,"notification":{"type":"email","to":["relevant_stakeholder"],"trigger":"ON_DEVIATION","within_minutes":15,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.97,"tags":["notification","deviation","three_way_match","sla"]},{"rule_id":"AP-NOT-002","source_clause":"Section 6.2","description":"Email notification must include: Invoice Number, Vendor Name, PO Number, Deviation Type, Deviation Details (expected vs actual), and Recommended Action.","category":"DEVIATION_NOTIFICATIONS","priority":91,"scope":"INVOICE","condition":{"field":"notification_sent","op":"eq","value":true},"action":"VALIDATE_NOTIFICATION_CONTENT","action_details":{"required_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"requires_justification":false,"notification":null,"confidence":0.98,"tags":["notification","content_validation"]},{"rule_id":"AP-NOT-003","source_clause":"Section 6.3","description":"If a deviation is not resolved within 48 hours, an automatic escalation email must be sent to the next-level approver as defined in Section 5.","category":"DEVIATION_NOTIFICATIONS","priority":92,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"has_unresolved_deviation","op":"eq","value":true},{"field":"deviation_age_hours","op":"gt","value":48}]},"action":"ESCALATE_NOTIFICATION","action_details":{"route_to":"NEXT_LEVEL_APPROVER","cross_reference":"Section 5 — approval hierarchy","reason":"Deviation unresolved for more than 48 hours"},"requires_justification":false,"notification":{"type":"email","to":["next_level_approver"],"trigger":"ON_48H_BREACH","within_minutes":0,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.97,"tags":["notification","escalation","48h_sla","deviation"]},{"rule_id":"AP-NOT-004","source_clause":"Section 6.4","description":"Critical deviations (amount variance > 10% or compliance failures from Section 4) must trigger an immediate email to Finance Controller and Internal Audit simultaneously.","category":"DEVIATION_NOTIFICATIONS","priority":88,"scope":"INVOICE","condition":{"operator":"OR","operands":[{"field":"amount_deviation_pct","op":"gt","value":10},{"field":"has_compliance_failure","op":"eq","value":true}]},"action":"SEND_CRITICAL_NOTIFICATION","action_details":{"route_to":["FINANCE_CONTROLLER","INTERNAL_AUDIT"],"reason":"Critical deviation: amount variance > 10% or compliance failure detected"},"requires_justification":false,"notification":{"type":"email","to":["finance_controller","internal_audit"],"trigger":"IMMEDIATE","within_minutes":0,"include_fields":["invoice_number","vendor_name","po_number","deviation_type","deviation_details","recommended_action"]},"confidence":0.98,"tags":["notification","critical_deviation","immediate","finance_controller","internal_audit"]},{"rule_id":"AP-QR-001","source_clause":"Section 7.1","description":"For invoices above INR 10,00,000, a valid QR code must be present as per GST e-invoicing norms. Missing QR code results in a hold.","category":"QR_VALIDATION","priority":70,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"invoice_total","op":"gt","value":1000000},{"field":"has_qr_code","op":"eq","value":false}]},"action":"HOLD","action_details":{"status":"HELD","flag":"QR Code Missing — E-Invoice Compliance Required","route_to":"AP_CLERK","reason":"Invoice above INR 10L missing mandatory QR code per GST e-invoicing norms"},"requires_justification":false,"notification":null,"confidence":0.99,"tags":["qr_code","e_invoicing","compliance","hold"]},{"rule_id":"AP-QR-002","source_clause":"Section 7.2","description":"If QR code is present, Invoice Number and Vendor GSTIN extracted from QR code must match corresponding fields on the invoice face. Mismatch results in QR Validation Failed flag.","category":"QR_VALIDATION","priority":72,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"has_qr_code","op":"eq","value":true},{"operator":"OR","operands":[{"field":"qr_invoice_number","op":"neq","value_field":"invoice_number"},{"field":"qr_vendor_gstin","op":"neq","value_field":"vendor_gstin"}]}]},"action":"FLAG_ERROR","action_details":{"status":"FLAGGED","flag":"QR Validation Failed","route_to":"AP_CLERK","reason":"QR code data does not match invoice fields"},"requires_justification":false,"notification":null,"confidence":0.98,"tags":["qr_code","e_invoicing","validation","error"]},{"rule_id":"AP-QR-003","source_clause":"Section 7.3","description":"Digital signature is recommended but not mandatory. If present and invalid, flag for manual review.","category":"QR_VALIDATION","priority":74,"scope":"INVOICE","condition":{"operator":"AND","operands":[{"field":"digital_signature_present","op":"eq","value":true},{"field":"digital_signature_valid","op":"eq","value":false}]},"action":"FLAG_WARNING","action_details":{"status":"FLAGGED","flag":"Signature Verification Failed","route_to":"AP_CLERK","reason":"Digital signature is present but invalid — manual review required"},"requires_justification":false,"notification":null,"confidence":0.96,"tags":["digital_signature","validation","warning"]}]